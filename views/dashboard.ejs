<%- include('partials/header', { title: 'لوحة التحكم', page: 'dashboard' }) %>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-xl-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3 p-3 p-md-4">
        <div class="stat-icon bg-success-subtle rounded-3 p-3 text-success"><i class="bi bi-arrow-down-circle-fill fs-2"></i></div>
        <div class="min-w-0">
          <div class="text-muted small mb-1" data-i18n="stat_total_income">إجمالي الإيرادات</div>
          <div class="fw-bold fs-4 fs-md-3 text-success" id="totalIncome">—</div>
          <div class="text-muted small"><span id="incomeCount">—</span> <span data-i18n="stat_income_ops">عملية قبض</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-xl-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3 p-3 p-md-4">
        <div class="stat-icon bg-danger-subtle rounded-3 p-3 text-danger"><i class="bi bi-arrow-up-circle-fill fs-2"></i></div>
        <div class="min-w-0">
          <div class="text-muted small mb-1" data-i18n="stat_total_expenses">إجمالي المصروفات</div>
          <div class="fw-bold fs-4 fs-md-3 text-danger" id="totalExpenses">—</div>
          <div class="text-muted small"><span id="expensesCount">—</span> <span data-i18n="stat_expense_ops">عملية صرف</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-12 col-xl-4">
    <div class="card stat-card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3 p-3 p-md-4">
        <div class="stat-icon bg-primary-subtle rounded-3 p-3 text-primary"><i class="bi bi-graph-up-arrow fs-2"></i></div>
        <div class="min-w-0">
          <div class="text-muted small mb-1" data-i18n="stat_net_profit">صافي الربح</div>
          <div class="fw-bold fs-4 fs-md-3" id="netProfit">—</div>
          <div class="small" id="profitStatus">—</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Shortcuts -->
<div class="row g-3 mb-4">
  <div class="col-md-6">
    <a href="/income" class="card card-hover border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body d-flex align-items-center gap-3 p-3">
        <div class="rounded-circle bg-success d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
          <i class="bi bi-plus-lg text-white fs-5"></i>
        </div>
        <div class="min-w-0">
          <div class="fw-semibold text-dark" data-i18n="shortcut_add_income">إضافة عملية قبض</div>
          <div class="text-muted small" data-i18n="shortcut_add_income_sub">تسجيل إيراد جديد</div>
        </div>
        <i class="bi bi-chevron-left text-muted ms-auto flex-shrink-0"></i>
      </div>
    </a>
  </div>
  <div class="col-md-6">
    <a href="/expenses" class="card card-hover border-0 shadow-sm text-decoration-none h-100">
      <div class="card-body d-flex align-items-center gap-3 p-3">
        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px">
          <i class="bi bi-plus-lg text-white fs-5"></i>
        </div>
        <div class="min-w-0">
          <div class="fw-semibold text-dark" data-i18n="shortcut_add_expense">إضافة مصروف</div>
          <div class="text-muted small" data-i18n="shortcut_add_expense_sub">تسجيل مصروف جديد</div>
        </div>
        <i class="bi bi-chevron-left text-muted ms-auto flex-shrink-0"></i>
      </div>
    </a>
  </div>
</div>

<!-- Chart -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0 pt-3 pb-0">
    <h6 class="card-title mb-0 fw-bold">
      <i class="bi bi-bar-chart-line text-primary me-2"></i><span data-i18n="chart_title">الإيرادات والمصروفات — آخر 30 يوماً</span>
    </h6>
  </div>
  <div class="card-body">
    <div id="chartPlaceholder" class="text-center text-muted py-5">
      <div class="spinner-border text-primary" role="status"></div>
      <div class="mt-2 small" data-i18n="chart_loading">جاري تحميل البيانات...</div>
    </div>
    <canvas id="mainChart" style="display:none"></canvas>
  </div>
</div>

<%- include('partials/footer', { pageScript: '/js/dashboard.js' }) %>
